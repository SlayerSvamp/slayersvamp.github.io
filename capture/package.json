{
  "name": "capture",
  "version": "1.0.0",
  "description": "A simple **client-side** React app (via CDN + Babel) that stores notes in **localStorage**.",
  "main": "dist/app.js",
  "scripts": {
    "build": "esbuild src/app.tsx --bundle --platform=browser --target=es2020 --outfile=dist/app.js --sourcemap",
    "watch": "esbuild src/app.tsx --bundle --platform=browser --target=es2020 --outfile=dist/app.js --sourcemap --watch",
    "serve": "serve -s . -l 5000",
    "prestart": "npm run build",
    "start": "npm run serve"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.27.4",
    "serve": "^14.2.6"
  }
}
